<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hospital Update Form</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, sans-serif;
}

body{
    background:linear-gradient(to right,#dfefff,#f8fcff);
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
}

.form-container{
    background:white;
    width:450px;
    padding:35px;
    border-radius:15px;
    box-shadow:0 10px 30px rgba(0,0,0,0.15);
}

h1{
    text-align:center;
    color:#0077b6;
    margin-bottom:25px;
}

.input-group{
    margin-bottom:18px;
}

label{
    display:block;
    margin-bottom:6px;
    color:#555;
    font-weight:bold;
}

input{
    width:100%;
    padding:12px;
    border:1px solid #cfd9e0;
    border-radius:8px;
    font-size:15px;
}

input:focus{
    outline:none;
    border-color:#0096c7;
    box-shadow:0 0 10px rgba(0,150,199,0.2);
}

button{
    width:100%;
    padding:14px;
    background:#0096c7;
    color:white;
    border:none;
    border-radius:8px;
    font-size:18px;
    cursor:pointer;
    transition:0.3s;
}

button:hover{
    background:#0077b6;
}

</style>

</head>

<body>

<div class="form-container">

<h1>🏥 Update Patient</h1>

<form action="/update/<%= data.id %>" method="POST">

<div class="input-group">
<label>Name</label>
<input type="text" name="name" placeholder="Enter Patient Name">
</div>

<div class="input-group">
<label>Age</label>
<input type="number" name="age" placeholder="Enter Age">
</div>

<div class="input-group">
<label>Disease</label>
<input type="text" name="disease" placeholder="Enter Disease">
</div>

<div class="input-group">
<label>Doctor Name</label>
<input type="text" name="doctorname" placeholder="Doctor Name">
</div>

<div class="input-group">
<label>Fees</label>
<input type="number" name="fees" placeholder="Enter Fees">
</div>

<button type="submit">
Update Patient
</button>

</form>

</div>

</body>
</html>